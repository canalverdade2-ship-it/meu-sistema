# -----------------------------------------------------------------------------
# FRONTEND — valores públicos incorporados ao bundle
# Nunca use o prefixo VITE_ em chaves administrativas ou service_role.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"
VITE_ERROR_REPORTING_ENDPOINT="https://errors.example.com/v1/client-errors"

# URL pública principal do sistema, usada em links e callbacks.
APP_URL="https://grupo-gsa.com.br"

# -----------------------------------------------------------------------------
# SUPABASE — somente servidor, Edge Functions e CI/CD
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="set-in-secret-manager"
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_ACCESS_TOKEN="set-in-github-secrets"
SUPABASE_DB_PASSWORD="set-in-github-secrets"
SUPABASE_DB_URL="postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres"

# Origens exatas autorizadas nas Edge Functions, separadas por vírgula.
ALLOWED_ORIGINS="https://grupo-gsa.com.br,https://www.grupo-gsa.com.br"
ALLOWED_ORIGIN="https://grupo-gsa.com.br"

# -----------------------------------------------------------------------------
# PUBLICIDADE
# Gere valores aleatórios fortes e independentes para cada segredo.
# -----------------------------------------------------------------------------
AD_DELIVERY_HASH_SALT="set-in-supabase-secrets"
ADVERTISING_WEBHOOK_SECRET="set-in-supabase-secrets"
ADVERTISING_CRON_SECRET="set-in-supabase-secrets"

# -----------------------------------------------------------------------------
# IMPORTAÇÃO INTELIGENTE DE PRODUTOS
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY="set-in-supabase-secrets"
OPENROUTER_HTTP_REFERER="https://grupo-gsa.com.br"
OPENROUTER_APP_NAME="Grupo GSA - Importador de Produtos"
PRODUCT_IMPORT_ALLOWED_ORIGINS="https://grupo-gsa.com.br,https://www.grupo-gsa.com.br"
PRODUCT_IMPORT_VISION_MODEL="google/gemma-4-26b-a4b-it:free"
PRODUCT_IMPORT_VISION_FALLBACK_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free"
PRODUCT_IMPORT_TEXT_MODEL="qwen/qwen3-next-80b-a3b-instruct:free"

# -----------------------------------------------------------------------------
# INTEGRAÇÕES OPCIONAIS
# -----------------------------------------------------------------------------
GEMINI_API_KEY="set-in-secret-manager"

# Testes que gravam dados reais permanecem desabilitados por padrão.
ALLOW_REAL_DATA_STRESS_TEST="false"
